{
  "name": "classintel-ai",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "cross-env BACKEND_PORT=5001 concurrently -n backend,frontend -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "npm --prefix frontend run dev",
    "build:frontend": "npm --prefix frontend run build",
    "dev:backend": "npm --prefix backend run dev",
    "build:backend": "npm --prefix backend run build",
    "check": "npm --prefix backend run check && npm --prefix frontend run check",
    "build": "npm run build:backend",
    "start": "npm run start:backend",
    "start:backend": "npm --prefix backend run start",
    "db:push": "npm --prefix backend run db:push",
    "db:generate": "npm --prefix backend run db:generate",
    "db:migrate": "npm --prefix backend run db:migrate",
    "db:seed": "npm --prefix backend run db:seed"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "typescript": "^5.3.3",
    "vite": "^7.3.1"
  }
}
